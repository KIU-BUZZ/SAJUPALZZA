            display: inline-block; margin-top: 6px; padding: 2px 10px; border-radius: 20px;
            font-size: 0.72rem; font-weight: 700; color: #fff;
        }

        /* Seun Card */
        .seun-row {
            display: grid; grid-template-columns: 80px 1fr 60px; gap: 16px;
            align-items: center; padding: 16px 0; border-bottom: 1px solid var(--border);
        }
        .seun-row:last-child { border-bottom: none; }
        .seun-year { font-size: 1.2rem; font-weight: 800; text-align: center; }
        .seun-year small { display: block; font-size: 0.72rem; font-weight: 400; color: var(--text-muted); }
        .seun-body { font-size: 0.85rem; line-height: 1.7; color: var(--text-secondary); }
        .seun-score { font-size: 1.1rem; font-weight: 800; text-align: center; }

        /* Fortune Section */
        .fortune-grid { display: grid; grid-template-columns: 1fr; gap: 0; }
        .fortune-item {
            padding: 20px 0; border-bottom: 1px solid var(--border);
        }
        .fortune-item:last-child { border-bottom: none; }
        .fortune-item-head {
            display: flex; align-items: center; gap: 10px; margin-bottom: 10px;
        }
        .fortune-item-icon {
            width: 32px; height: 32px; border-radius: 8px; display: flex;
            align-items: center; justify-content: center; font-size: 0.85rem; color: #fff; flex-shrink: 0;
        }
        .fortune-item-title { font-size: 0.95rem; font-weight: 700; }
        .fortune-item-text { font-size: 0.88rem; color: var(--text-secondary); line-height: 1.85; white-space: pre-line; }

        /* Relationship tags */
        .rel-tag {
            display: inline-flex; align-items: center; padding: 3px 10px;
            border-radius: 6px; font-size: 0.72rem; font-weight: 700; margin-right: 4px;
        }

        /* Sipsin rule card */
        .sipsin-card {
            border-radius: 12px; padding: 16px 18px; margin-bottom: 10px;
            border-left: 4px solid var(--accent); background: #FAFBFC;
        }
        .sipsin-card .sc-head { display: flex; align-items: center; gap: 8px; margin-bottom: 6px; }
        .sipsin-card .sc-level {
            font-size: 0.68rem; font-weight: 700; padding: 2px 8px; border-radius: 4px; color: #fff;
        }
        .sipsin-card .sc-title { font-weight: 700; font-size: 0.88rem; }
        .sipsin-card .sc-text { font-size: 0.82rem; color: var(--text-secondary); line-height: 1.7; white-space: pre-line; }

        /* Info block */
        .info-block {
            background: #F8F9FA; border-radius: 12px; padding: 16px 20px;
            font-size: 0.88rem; line-height: 1.8; color: var(--text-secondary); white-space: pre-line;
            margin-top: 12px;
        }

        /* Report Footer */
        .report-footer {
            text-align: center; padding: 24px 40px; background: #F8F9FA;
            border-top: 1px solid var(--border);
        }
        .report-footer p { font-size: 0.78rem; color: var(--text-muted); }

        /* Jijanggan compact */
        .jjg-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 10px; }
        .jjg-item { background: #FAFBFC; border-radius: 10px; padding: 12px; text-align: center; border: 1px solid var(--border); }
        .jjg-item .jjg-label { font-size: 0.7rem; color: var(--text-muted); font-weight: 600; margin-bottom: 6px; }

        /* Score pill */
        .score-pill { display: inline-block; padding: 3px 12px; border-radius: 20px; font-size: 0.75rem; font-weight: 700; }
        .sp-high { background: #E8F5E9; color: #2E7D32; }
        .sp-mid { background: #E3F2FD; color: #1565C0; }
        .sp-low { background: #FFF3E0; color: #E65100; }
        .sp-danger { background: #FFEBEE; color: #C62828; }

        /* Supplement block */
        .sup-card {
            border: 1px solid var(--border); border-radius: 10px; padding: 14px 16px;
            margin-bottom: 8px; background: #FAFBFC;
        }
        .sup-card .sup-head { font-weight: 700; font-size: 0.88rem; margin-bottom: 6px; display: flex; align-items: center; gap: 6px; }
        .sup-card ul { list-style: none; padding: 0; margin: 0; }
        .sup-card li { font-size: 0.82rem; color: var(--text-secondary); padding: 3px 0; padding-left: 16px; position: relative; }
        .sup-card li::before { content: '✦'; position: absolute; left: 0; color: var(--accent); }

        /* Print */
        @media print {
            body { background: #fff !important; }
            .sidebar, .topbar, .no-print { display: none !important; }
            .main { margin-left: 0 !important; }
            .container { padding: 0 !important; max-width: 100% !important; }
            .report { box-shadow: none !important; border: none !important; }
            .rpt-section { page-break-inside: avoid; }
            .report-hero { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
        }
        @media (max-width: 768px) {
            .sidebar { width: 60px; }
            .sidebar-brand h2 span, .sidebar-brand small, .sidebar-nav a span { display: none; }
            .sidebar-nav a { justify-content: center; padding: 12px; }
            .sidebar-footer { display: none; }
            .main { margin-left: 60px; }
            .container { padding: 16px; }
            .rpt-section { padding: 20px; }
            .report-hero { padding: 24px 20px; }
            .god-grid { grid-template-columns: 1fr 1fr; }
            .form-grid { grid-template-columns: 1fr; }
