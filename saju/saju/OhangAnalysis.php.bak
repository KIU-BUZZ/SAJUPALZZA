<?php
/**
 * 오행 분석 클래스
 * 사주에 포함된 오행(목화토금수)을 분석
 */

require_once __DIR__ . '/SajuEngine.php';

class OhangAnalysis {
    
    private $engine;
    private $ohangCount;
    
    // 오행 상생 관계 (생하는 관계)
    const OHANG_GENERATE = [
        '목' => '화', '화' => '토', '토' => '금', '금' => '수', '수' => '목'
    ];
    
    // 오행 상극 관계 (극하는 관계)
    const OHANG_CONTROL = [
        '목' => '토', '화' => '금', '토' => '수', '금' => '목', '수' => '화'
    ];
    
    // 오행별 한자/영문/속성
    const OHANG_PROPERTIES = [
        '목' => ['hanja' => '木', 'nature' => '나무', 'season' => '봄', 'direction' => '동', 'color' => '파랑/초록', 'character' => '성장, 인자, 자비'],
        '화' => ['hanja' => '火', 'nature' => '불', 'season' => '여름', 'direction' => '남', 'color' => '빨강', 'character' => '예의, 열정, 표현'],
        '토' => ['hanja' => '土', 'nature' => '흙', 'season' => '환절기', 'direction' => '중앙', 'color' => '노랑', 'character' => '신의, 안정, 포용'],
        '금' => ['hanja' => '金', 'nature' => '쇠', 'season' => '가을', 'direction' => '서', 'color' => '흰색', 'character' => '의리, 결단, 추진력'],
        '수' => ['hanja' => '水', 'nature' => '물', 'season' => '겨울', 'direction' => '북', 'color' => '검정', 'character' => '지혜, 적응, 유연'],
    ];
    
    /**
     * 생성자
     * @param SajuEngine $engine
     */
    public function __construct(SajuEngine $engine) {
        $this->engine = $engine;
        $this->ohangCount = $this->countOhang();
    }
    
    /**
     * 사주 내 오행 개수 계산
     * @return array
     */
    private function countOhang() {
        $count = ['목' => 0, '화' => 0, '토' => 0, '금' => 0, '수' => 0];
        $elements = $this->engine->getAllElements();
        
        // 천간 오행 분석
        foreach ($elements['stems'] as $stemIndex) {
            $stem = SajuEngine::CHEONGAN[$stemIndex];
            $element = SajuEngine::CHEONGAN_OHANG[$stem];
            $count[$element]++;
        }
        
        // 지지 오행 분석
        foreach ($elements['branches'] as $branchIndex) {
            $branch = SajuEngine::JIJI[$branchIndex];
            $element = SajuEngine::JIJI_OHANG[$branch];
            $count[$element]++;
        }
        
        return $count;
    }
    
    /**
     * 전체 오행 분석 결과 반환
     * @return array
     */
    public function analyze() {
        $dayMasterElement = $this->engine->getDayMasterElement();
        
        return [
            'day_master_element' => $dayMasterElement,
            'day_master_element_hanja' => self::OHANG_PROPERTIES[$dayMasterElement]['hanja'],
            'ohang_count' => $this->ohangCount,
            'total' => array_sum($this->ohangCount),
            'strong_elements' => $this->getStrongElements(),
            'weak_elements' => $this->getWeakElements(),
            'missing_elements' => $this->getMissingElements(),
            'balance' => $this->getBalanceScore(),
            'balance_description' => $this->getBalanceDescription(),
            'properties' => self::OHANG_PROPERTIES,
            'interpretation' => $this->getInterpretation(),
            'relationships' => $this->getRelationships(),
        ];
    }
    
    /**
     * 강한 오행 (2개 이상)
     * @return array
     */
    private function getStrongElements() {
        return array_keys(array_filter($this->ohangCount, function($v) { return $v >= 2; }));
    }
    
    /**
     * 약한 오행 (1개 이하)
     * @return array
     */
    private function getWeakElements() {
        return array_keys(array_filter($this->ohangCount, function($v) { return $v == 1; }));
    }
    
    /**
     * 없는 오행 (0개)
     * @return array
     */
    private function getMissingElements() {
        return array_keys(array_filter($this->ohangCount, function($v) { return $v == 0; }));
    }
    
    /**
     * 오행 균형 점수 (0-100)
     * @return int
     */
    private function getBalanceScore() {
        $total = array_sum($this->ohangCount);
        if ($total == 0) return 0;
        
        $ideal = $total / 5; // 이상적 균등 분배
        $deviation = 0;
        
        foreach ($this->ohangCount as $count) {
            $deviation += abs($count - $ideal);
        }
        
        // 편차가 작을수록 높은 점수
        $maxDeviation = $total * 0.8; // 최대 편차
        $score = max(0, 100 - ($deviation / $maxDeviation * 100));
        
        return (int)round($score);
    }
    
    /**
     * 균형 상태 설명
     * @return string
     */
    private function getBalanceDescription() {
        $score = $this->getBalanceScore();
        
        if ($score >= 80) return '매우 균형 잡힌 오행 구성입니다.';
        if ($score >= 60) return '비교적 균형 잡힌 오행 구성입니다.';
        if ($score >= 40) return '약간의 오행 편중이 있습니다.';
        if ($score >= 20) return '오행의 편중이 비교적 큰 편입니다.';
        return '오행의 편중이 매우 큰 편입니다.';
    }
    
    /**
     * 오행 해석
     * @return array
     */
    private function getInterpretation() {
        $dayMasterElement = $this->engine->getDayMasterElement();
        $strong = $this->getStrongElements();
        $weak = $this->getWeakElements();
        $missing = $this->getMissingElements();
        
        $interpretation = [];
        
        // 일간 오행 해석
        $props = self::OHANG_PROPERTIES[$dayMasterElement];
        $interpretation['day_master'] = sprintf(
            "당신의 일간 오행은 %s(%s)입니다. %s의 기운을 타고났으며, %s과(와) 관련된 성격적 특성을 지닙니다. %s의 계절에 가장 활력이 넘치며, %s 방위가 길합니다.",
            $dayMasterElement, $props['hanja'], $props['nature'], $props['character'], $props['season'], $props['direction']
        );
        
        // 강한 오행 해석
        if (!empty($strong)) {
            $strongNames = array_map(function($e) {
                return $e . '(' . self::OHANG_PROPERTIES[$e]['hanja'] . ')';
            }, $strong);
            $interpretation['strong'] = sprintf(
                "사주에서 %s의 기운이 강합니다. ",
                implode(', ', $strongNames)
            );
            foreach ($strong as $element) {
                $interpretation['strong'] .= self::getElementStrengthMeaning($element, true) . ' ';
            }
        }
        
        // 약한/부족한 오행 해석
        if (!empty($missing)) {
            $missingNames = array_map(function($e) {
                return $e . '(' . self::OHANG_PROPERTIES[$e]['hanja'] . ')';
            }, $missing);
            $interpretation['missing'] = sprintf(
                "사주에 %s의 기운이 부족합니다. ",
                implode(', ', $missingNames)
            );
            foreach ($missing as $element) {
                $interpretation['missing'] .= self::getElementStrengthMeaning($element, false) . ' ';
            }
        }
        
        // 보완 조언
        $interpretation['advice'] = $this->getBalanceAdvice();
        
        return $interpretation;
    }
    
    /**
     * 오행 강약에 따른 의미
     * @param string $element
     * @param bool $isStrong
     * @return string
     */
    private static function getElementStrengthMeaning($element, $isStrong) {
        $meanings = [
            '목' => [
                'strong' => '추진력과 성장 에너지가 강하여 새로운 일을 시작하는 데 유리합니다. 다만 고집이 셀 수 있으니 유연함을 기르세요.',
                'weak' => '시작하는 힘과 결단력을 보완하면 좋겠습니다. 봄의 기운과 녹색이 도움이 됩니다.'
            ],
            '화' => [
                'strong' => '열정과 표현력이 뛰어납니다. 예술적 감각이 있으나 감정 조절에 주의하세요.',
                'weak' => '열정과 적극성을 보완하면 좋겠습니다. 빨간색이나 따뜻한 환경이 도움이 됩니다.'
            ],
            '토' => [
                'strong' => '안정감과 포용력이 뛰어납니다. 신뢰할 수 있는 사람이지만 변화에 대한 두려움을 줄여보세요.',
                'weak' => '안정감과 중심을 잡는 힘을 보완하면 좋겠습니다. 황색 계열이 도움이 됩니다.'
            ],
            '금' => [
                'strong' => '의리와 결단력이 뛰어납니다. 추진력이 강하지만 너무 냉정하지 않도록 주의하세요.',
                'weak' => '결단력과 추진력을 보완하면 좋겠습니다. 흰색이나 금속 소재가 도움이 됩니다.'
            ],
            '수' => [
                'strong' => '지혜롭고 적응력이 뛰어납니다. 융통성이 좋지만 우유부단하지 않도록 하세요.',
                'weak' => '지혜와 유연성을 보완하면 좋겠습니다. 검정색이나 물 관련 환경이 도움이 됩니다.'
            ],
        ];
        
        $key = $isStrong ? 'strong' : 'weak';
        return $meanings[$element][$key] ?? '';
    }
    
    /**
     * 오행 균형 보완 조언
     * @return string
     */
    private function getBalanceAdvice() {
        $missing = $this->getMissingElements();
        $weak = $this->getWeakElements();
        $needElements = array_merge($missing, $weak);
        
        if (empty($needElements)) {
            return "오행이 대체로 균형을 이루고 있어 안정적인 사주입니다. 현재의 균형을 잘 유지하세요.";
        }
        
        $advices = [];
        foreach ($needElements as $element) {
            $props = self::OHANG_PROPERTIES[$element];
            $advices[] = sprintf(
                "%s(%s)의 기운을 보완하기 위해 %s 색상의 물건이나 %s쪽 방위를 활용해 보세요.",
                $element, $props['hanja'], $props['color'], $props['direction']
            );
        }
        
        return implode(' ', $advices);
    }
    
    /**
     * 오행 관계 분석
     * @return array
     */
    private function getRelationships() {
        $dayMasterElement = $this->engine->getDayMasterElement();
        
        return [
            'generates' => [
                'element' => self::OHANG_GENERATE[$dayMasterElement],
                'meaning' => sprintf("%s(%s)이(가) %s(%s)을(를) 생합니다 (상생).",
                    $dayMasterElement, self::OHANG_PROPERTIES[$dayMasterElement]['hanja'],
                    self::OHANG_GENERATE[$dayMasterElement], self::OHANG_PROPERTIES[self::OHANG_GENERATE[$dayMasterElement]]['hanja']
                )
            ],
            'controls' => [
                'element' => self::OHANG_CONTROL[$dayMasterElement],
                'meaning' => sprintf("%s(%s)이(가) %s(%s)을(를) 극합니다 (상극).",
                    $dayMasterElement, self::OHANG_PROPERTIES[$dayMasterElement]['hanja'],
                    self::OHANG_CONTROL[$dayMasterElement], self::OHANG_PROPERTIES[self::OHANG_CONTROL[$dayMasterElement]]['hanja']
                )
            ],
            'generated_by' => [
                'element' => array_search($dayMasterElement, self::OHANG_GENERATE),
                'meaning' => sprintf("%s을(를) 생하는 오행은 %s입니다.",
                    $dayMasterElement, array_search($dayMasterElement, self::OHANG_GENERATE)
                )
            ],
            'controlled_by' => [
                'element' => array_search($dayMasterElement, self::OHANG_CONTROL),
                'meaning' => sprintf("%s을(를) 극하는 오행은 %s입니다.",
                    $dayMasterElement, array_search($dayMasterElement, self::OHANG_CONTROL)
                )
            ],
        ];
    }
}
