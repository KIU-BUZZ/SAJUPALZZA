<?php
/**
 * ========================================
 * 운세 해석 엔진 (FortuneInterpreter)
 * ========================================
 * 
 * 명리학 이론 기반 포괄적 운세 해석
 * 
 * [핵심 기능]
 * 1. 격국(格局) 분석 — 사주의 중심 구조 판별
 * 2. 대운(大運) — 10년 단위 운세, 원국과 합충형파해 분석
 * 3. 세운(歲運) — 연 단위 운세, 원국+대운 상호작용
 * 4. 조건 기반 규칙 엔진 — 십성 조합에 따른 맞춤 해석
 * 5. 종합 운세 — 성격/연애/직업/재물/학업/인생흐름 상세 해석
 */

class FortuneInterpreter {

    private $engine;
    private $result;
    private $ohangAnalysis;
    private $ohangData;

    public function __construct(SajuEngine $engine) {
        $this->engine = $engine;
        $this->result = $engine->getResult();
        $this->ohangAnalysis = new OhangAnalysis($engine);
        $this->ohangData = $this->ohangAnalysis->analyze();
    }

    public function getOhangData() { return $this->ohangData; }

    // ================================================================
    // 십성 분석 (지장간 포함 상세 분석)
    // ================================================================
    public function analyzeSipsin() {
        $sipsinFull = $this->result['sipsin_full'];
        $dist = $sipsinFull['distribution'];
        $dominant = $sipsinFull['dominant_sipsin'];
        $dominantInfo = $sipsinFull['dominant_sipsin_info'];

        // 십성 그룹핑
        $groups = [
            '비겁(比劫)' => ['비견','겁재'],
            '식상(食傷)' => ['식신','상관'],
            '재성(財星)' => ['편재','정재'],
            '관성(官星)' => ['편관','정관'],
            '인성(印星)' => ['편인','정인'],
        ];
        $groupTotals = [];
        foreach ($groups as $gName => $members) {
            $total = 0;
            foreach ($members as $m) $total += ($dist[$m] ?? 0);
            $groupTotals[$gName] = round($total, 2);
        }
        arsort($groupTotals);

        // 조건 기반 해석
        $interpretations = $this->interpretSipsinCombination($dist, $groupTotals);

        return [
            'pillars_detail' => $sipsinFull['pillars'],
            'distribution' => $dist,
            'group_totals' => $groupTotals,
            'dominant' => $dominant,
            'dominant_info' => $dominantInfo,
            'interpretations' => $interpretations,
        ];
    }

    /**
     * 조건 기반 규칙 엔진 — 십성 조합에 따른 맞춤 해석
     * 예: 재성 강함+관성 약함 → "돈을 벌 능력은 있으나 직장 안정성은 약한 경향"
     */
    private function interpretSipsinCombination($dist, $groups) {
        $rules = [];
        $bigyeop  = $groups['비겁(比劫)'] ?? 0;
        $siksang  = $groups['식상(食傷)'] ?? 0;
        $jaesung  = $groups['재성(財星)'] ?? 0;
        $gwansung = $groups['관성(官星)'] ?? 0;
        $insung   = $groups['인성(印星)'] ?? 0;
        $dms = $this->result['day_master_strength'];
        $isStrong = $dms['is_strong'];

        // =========================================================
        // 규칙 1: 비겁 관련
        // =========================================================
        if ($bigyeop >= 3.0) {
            $rules[] = ['category'=>'성격','title'=>'비겁(比劫) 과다','level'=>'주의',
                'text'=>'비겁이 매우 강합니다. 독립심과 자존심이 강하여 남에게 지기 싫어하고 혼자 해결하려는 성향이 큽니다. '.
                '경쟁에서는 강하지만, 고집이 세서 대인관계에서 충돌이 생길 수 있습니다. '.
                '협력하고 양보하는 자세를 기르면 더 큰 성과를 이룰 수 있습니다.'];
        }
        if ($bigyeop >= 2.0 && $jaesung <= 1.0) {
            $rules[] = ['category'=>'재물','title'=>'비겁 강 + 재성 약','level'=>'경고',
                'text'=>'비겁이 강하고 재성이 약합니다. 이는 돈이 들어와도 쉽게 빠져나가는 구조입니다. '.
                '주변 사람들에게 베푸는 것은 좋지만, 재무 관리를 체계적으로 해야 합니다. '.
                '동업보다는 독자적으로 사업하는 것이 유리합니다.'];
        }
        if ($bigyeop <= 0.5 && $gwansung >= 2.0) {
            $rules[] = ['category'=>'성격','title'=>'비겁 부족 + 관성 강','level'=>'주의',
                'text'=>'자기 주장이 약한데 외부 압박(관성)이 강합니다. '.
                '직장이나 사회에서 스트레스를 많이 받을 수 있으며, 자신의 의견을 표현하는 훈련이 필요합니다. '.
                '운동이나 취미 활동으로 스트레스를 해소하는 것이 좋습니다.'];
        }

        // =========================================================
        // 규칙 2: 식상 관련
        // =========================================================
        if ($siksang >= 3.0) {
            $rules[] = ['category'=>'성격','title'=>'식상(食傷) 과다','level'=>'양면',
                'text'=>'표현력과 창의력이 매우 뛰어납니다! 말을 잘하고, 예술적 감각도 강합니다. '.
                '하지만 참을성이 부족하고, 규칙이나 제약을 싫어하는 경향이 있습니다. '.
                '자유로운 직종(프리랜서, 예술, 기획, 콘텐츠 등)에서 빛을 발합니다.'];
        }
        if ($siksang >= 2.0 && $jaesung >= 2.0) {
            $rules[] = ['category'=>'재물','title'=>'식상생재(食傷生財)','level'=>'길',
                'text'=>'🎯 식상생재(食傷生財) 구조입니다! 이는 매우 좋은 구조로, '.
                '자신의 재능과 기술(식상)을 활용하여 돈(재성)을 벌 수 있다는 뜻입니다. '.
                '전문직, 기술직, 프리랜서, 사업 등에서 큰 수입을 올릴 수 있습니다. '.
                '꾸준히 능력을 개발하면 재물이 따라옵니다.'];
        }
        if ($siksang >= 2.0 && $gwansung >= 2.0) {
            $rules[] = ['category'=>'직업','title'=>'식상 강 + 관성 강','level'=>'갈등',
                'text'=>'창의성(식상)과 질서(관성)가 동시에 강하여, 자유롭고 싶으면서도 안정을 원하는 내면의 갈등이 있습니다. '.
                '직장 내에서 새로운 아이디어를 제안하되, 조직의 규율도 존중하는 균형이 필요합니다. '.
                'IT 기업, 벤처, 스타트업 등 자유로우면서도 체계적인 환경이 적합합니다.'];
        }

        // =========================================================
        // 규칙 3: 재성 관련
        // =========================================================
        if ($jaesung >= 3.0) {
            $rules[] = ['category'=>'재물','title'=>'재성(財星) 과다','level'=>'양면',
                'text'=>'재물 감각이 뛰어나고 현실적입니다. 돈 버는 능력은 탁월하지만, '.
                '지나치게 물질적인 가치에 집착할 수 있습니다. '.
                '과로와 건강 관리에 유의하세요. 또한 학문이나 자기 개발(인성)을 소홀히 하지 마세요.'];
        }
        if ($jaesung >= 2.0 && $gwansung <= 0.5) {
            $rules[] = ['category'=>'직업','title'=>'재성 강 + 관성 약','level'=>'참고',
                'text'=>'돈을 벌 능력은 있으나, 직장이나 조직에서의 안정성은 약한 편입니다. '.
                '회사원보다는 자영업이나 사업이 더 적합합니다. '.
                '자신만의 사업을 키우면 큰 성공을 이룰 수 있지만, 법적·행정적 부분도 신경 써야 합니다.'];
        }
        if ($jaesung >= 2.0 && $insung <= 0.5) {
            $rules[] = ['category'=>'학업','title'=>'재성 강 + 인성 약','level'=>'주의',
                'text'=>'실용적인 능력은 뛰어나지만, 학문적 깊이나 자기 성찰이 부족할 수 있습니다. '.
                '명리학에서 "재다인(財多印弱)"이라 하여, 돈에 정신을 빼앗기면 지혜가 흐려집니다. '.
                '꾸준한 독서와 공부를 병행하면 더 큰 그릇이 됩니다.'];
        }

        // =========================================================
        // 규칙 4: 관성 관련
        // =========================================================
        if ($gwansung >= 3.0) {
            $rules[] = ['category'=>'직업','title'=>'관성(官星) 과다','level'=>'주의',
                'text'=>'명예욕과 책임감이 매우 강합니다. 조직에서 높은 자리에 오를 수 있지만, '.
                '스트레스와 압박감도 그만큼 큽니다. 특히 편관(偏官)이 강하면 갑작스러운 변동이 있을 수 있어요. '.
                '마음의 여유를 갖고, 스트레스 관리에 신경 쓰세요.'];
        }
        if ($gwansung >= 2.0 && $insung >= 1.5) {
            $rules[] = ['category'=>'직업','title'=>'관인상생(官印相生)','level'=>'길',
                'text'=>'🎯 관인상생(官印相生) 구조입니다! 직장(관성)에서의 성과가 명예(인성)로 이어집니다. '.
                '공무원, 교수, 법조인, 대기업 등 안정적이고 사회적 지위가 있는 직업에서 성공하기 좋은 구조입니다. '.
                '꾸준히 학문을 닦고 경력을 쌓으면 큰 인정을 받게 됩니다.'];
        }

        // =========================================================
        // 규칙 5: 인성 관련
        // =========================================================
        if ($insung >= 3.0) {
            $rules[] = ['category'=>'성격','title'=>'인성(印星) 과다','level'=>'양면',
                'text'=>'학문적 소양이 깊고 사고력이 뛰어납니다. 배우는 것을 좋아하고 지적 수준이 높습니다. '.
                '다만 생각이 너무 많아 행동이 느릴 수 있고, 현실 감각이 떨어질 수 있습니다. '.
                '이론과 실천의 균형이 중요합니다. 배운 것을 행동으로 옮기세요!'];
        }
        if ($insung >= 2.0 && $siksang <= 0.5) {
            $rules[] = ['category'=>'성격','title'=>'인성 강 + 식상 약','level'=>'참고',
                'text'=>'많이 알지만 표현을 잘 못하는 유형입니다. 머릿속에는 좋은 아이디어가 가득하지만, '.
                '밖으로 표현하지 못해 아까운 경우가 많습니다. '.
                '글쓰기, 발표, SNS 활동 등을 통해 자기 표현 능력을 키우세요.'];
        }

        // =========================================================
        // 규칙 6: 신강/신약 + 용신 관련
        // =========================================================
        if ($isStrong && $siksang <= 0.5) {
            $rules[] = ['category'=>'운세','title'=>'신강 + 식상 부족','level'=>'참고',
                'text'=>'에너지는 넘치는데 발산할 출구(식상)가 부족합니다. '.
                '체력이 좋지만 에너지를 쓸 곳을 찾지 못해 답답할 수 있습니다. '.
                '운동, 창작 활동, 봉사 활동 등으로 에너지를 적극 발산하세요. '.
                '대운이나 세운에서 식상이 올 때 크게 도약할 수 있습니다.'];
        }
        if (!$isStrong && $gwansung >= 2.0) {
            $rules[] = ['category'=>'운세','title'=>'신약 + 관성 과다','level'=>'주의',
                'text'=>'⚠ 몸이 약한데 책임이 무거운 구조입니다. '.
                '직장에서 과도한 업무를 맡거나, 사회적 압박을 많이 받을 수 있습니다. '.
                '무리하지 말고 자신의 페이스를 지키세요. 인성(공부, 자기계발)을 통해 역량을 키우면 관성의 부담을 줄일 수 있습니다.'];
        }

        // 규칙이 없으면 기본 해석
        if (empty($rules)) {
            $rules[] = ['category'=>'종합','title'=>'균형 잡힌 사주','level'=>'길',
                'text'=>'십성이 비교적 고르게 분포되어 있습니다. 특별히 극단적인 편중이 없어 다방면에서 균형 잡힌 능력을 발휘할 수 있습니다. '.
                '다만, 뚜렷한 강점이 없을 수 있으니 자신만의 전문 분야를 개발하는 것이 좋습니다.'];
        }

        return $rules;
    }

    // ================================================================
    // 격국(格局) 분석
    // ================================================================
    public function analyzeGyeokguk() {
        $dist = $this->result['sipsin_full']['distribution'];
        $dms = $this->result['day_master_strength'];
        $isStrong = $dms['is_strong'];

        // 월지 본기의 십성으로 격국 결정 (정통 방법)
        $monthBranch = SajuEngine::JIJI[$this->engine->getMonthPillar()[1]];
        $jijangganList = SajuEngine::JIJANGGAN[$monthBranch];
        $lastItem = end($jijangganList); // 본기
        $bongGan = $lastItem[0];
        $bongEl = SajuEngine::CHEONGAN_OHANG[$bongGan];
        $bongYY = SajuEngine::CHEONGAN_YINYANG[array_search($bongGan, SajuEngine::CHEONGAN)];
        $dayElement = $this->result['day_master_element'];
        $dayYY = SajuEngine::CHEONGAN_YINYANG[$this->engine->getDayPillar()[0]];
        $mainSipsin = SajuEngine::getSipsin($dayElement, $dayYY, $bongEl, $bongYY);

        // 격국 이름 + 상세 해석
        $gyeokgukMap = [
            '비견' => ['name'=>'건록격(建祿格)','desc'=>'자립심이 강하고 독립적인 기질의 격국입니다.',
                'detail'=>"건록격은 일간과 같은 오행이 월지에 있어, 타고난 체력과 의지가 강합니다.\n\n".
                    "✅ 장점: 독립심, 자존심, 추진력이 강합니다. 혼자서도 잘 해내며 리더 기질이 있습니다.\n".
                    "⚠ 단점: 타인의 도움을 받기 어렵고, 고집이 셉니다. 동업은 피하는 것이 좋습니다.\n".
                    "💼 적합 직업: 자영업, 프리랜서, 전문직, 운동선수, CEO\n".
                    "💡 조언: 주변 사람들과 협력하는 법을 배우면 더 큰 성공을 이룰 수 있습니다."],
            '겁재' => ['name'=>'양인격(陽刃格)','desc'=>'승부욕이 강하고 도전적인 격국입니다.',
                'detail'=>"양인격은 강한 에너지를 가지고 있어, 어떤 분야든 최고를 추구합니다.\n\n".
                    "✅ 장점: 결단력, 승부근성, 강한 정신력을 갖추고 있습니다.\n".
                    "⚠ 단점: 과격하거나 무모한 면이 있을 수 있고, 대인 관계에서 마찰이 생기기 쉽습니다.\n".
                    "💼 적합 직업: 군인, 경찰, 검찰, 외과의사, 운동선수, 투자가\n".
                    "💡 조언: 정관(正官)으로 양인을 제어하면 큰 성공을 이룹니다."],
            '식신' => ['name'=>'식신격(食神格)','desc'=>'여유롭고 창의적이며 식복이 있는 격국입니다.',
                'detail'=>"식신격은 '복록격'이라고도 불리며, 타고난 복이 있는 격국입니다.\n\n".
                    "✅ 장점: 풍요롭고 여유로우며, 먹는 것을 즐기고 사교적입니다. 창의력이 뛰어납니다.\n".
                    "⚠ 단점: 게으를 수 있고, 도전 정신이 약할 수 있습니다.\n".
                    "💼 적합 직업: 요리사, 작가, 강사, 연예인, 카페/레스토랑 운영\n".
                    "💡 조언: 나태해지지 않도록 꾸준한 자기 관리가 필요합니다."],
            '상관' => ['name'=>'상관격(傷官格)','desc'=>'반항적이지만 천재적 재능을 지닌 격국입니다.',
                'detail'=>"상관격은 기존 질서를 깨뜨리고 새로운 것을 만드는 격국입니다.\n\n".
                    "✅ 장점: 독창적이고 언변이 뛰어나며, 남과 다른 관점을 가졌습니다. 예술적 천재성이 있습니다.\n".
                    "⚠ 단점: 권위에 반항하고 말로 상처를 줄 수 있으며, 직장 생활이 쉽지 않을 수 있습니다.\n".
                    "💼 적합 직업: 예술가, 변호사, 비평가, 유튜버, 강연자, 혁신 기업가\n".
                    "💡 조언: 재성(財星)이 있으면 상관의 에너지가 돈으로 전환됩니다(상관생재)."],
            '편재' => ['name'=>'편재격(偏財格)','desc'=>'사업 수완이 뛰어나고 대인관계가 좋은 격국입니다.',
                'detail'=>"편재격은 투기적 재물운이 강하며 스케일이 큰 격국입니다.\n\n".
                    "✅ 장점: 사업 감각이 뛰어나고 인맥이 넓습니다. 대범하고 통 큰 성격입니다.\n".
                    "⚠ 단점: 돈이 크게 벌리지만 크게 나갈 수도 있습니다. 투기에 주의하세요.\n".
                    "💼 적합 직업: 사업가, 트레이더, 부동산, 세일즈, 무역\n".
                    "💡 조언: 관성(官星)이 뒷받침되면 재물과 명예를 함께 얻습니다."],
            '정재' => ['name'=>'정재격(正財格)','desc'=>'근면성실하고 안정적인 재물운의 격국입니다.',
                'detail'=>"정재격은 '정당한 노력으로 얻는 재물'의 격국으로, 가장 안정적인 격입니다.\n\n".
