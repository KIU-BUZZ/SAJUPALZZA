<?php
/**
 * 운세 해석 엔진
 * 사주 분석을 기반으로 상세한 운세 해석 제공
 * 
 * 기능:
 * - 십신 분석
 * - 격국 분석
 * - 대운 분석
 * - 세운 분석
 * - 성격/연애/직업/재물/학문 운세
 */

require_once __DIR__ . '/SajuEngine.php';
require_once __DIR__ . '/OhangAnalysis.php';

class FortuneInterpreter {
    
    private $engine;
    private $ohangAnalysis;
    
    // ===== 십신 (Ten Gods) =====
    const SIPSIN = ['비견', '겁재', '식신', '상관', '편재', '정재', '편관', '정관', '편인', '정인'];
    
    // 십신 영문/설명
    const SIPSIN_INFO = [
        '비견' => ['desc' => '나와 같은 기운', 'meaning' => '자존심, 독립심, 경쟁심, 형제/동료 관계'],
        '겁재' => ['desc' => '나를 도우나 경쟁', 'meaning' => '승부욕, 대인관계, 경쟁, 외향적 성격'],
        '식신' => ['desc' => '내가 생하는 기운', 'meaning' => '표현력, 창의성, 식복, 자녀운, 예술적 감각'],
        '상관' => ['desc' => '내가 극하는 표현', 'meaning' => '반항심, 창의력, 언변, 자유분방함'],
        '편재' => ['desc' => '내가 극하는 재물', 'meaning' => '투기성 재물, 아버지, 사업 수완, 유동 자산'],
        '정재' => ['desc' => '내가 다스리는 재물', 'meaning' => '안정적 재물, 저축, 근면, 아내/여자'],
        '편관' => ['desc' => '나를 극하는 기운', 'meaning' => '권력, 명예, 도전, 변화, 스트레스'],
        '정관' => ['desc' => '나를 바르게 이끌', 'meaning' => '명예, 직장, 질서, 도덕성, 남편/남자'],
        '편인' => ['desc' => '나를 키우는 편모', 'meaning' => '학문, 비밀, 외로움, 특수한 재능'],
        '정인' => ['desc' => '나를 키우는 기운', 'meaning' => '학문, 어머니, 인자함, 안정, 명예'],
    ];
    
    // 오행 상생 순서 (생하는 방향)
    const OHANG_CYCLE = ['목', '화', '토', '금', '수'];
    
    // 격국 유형
    const GYEOKGUK_TYPES = [
        'strong_self'    => '신강(身強)',
        'weak_self'      => '신약(身弱)',
        'food_god'       => '식신격(食神格)',
        'wealth'         => '재성격(財星格)',
        'official'       => '관성격(官星格)',
        'seal'           => '인성격(印星格)',
        'comparison'     => '비겁격(比劫格)',
    ];
    
    // 12운성
    const TWELVE_STAGES = ['장생', '목욕', '관대', '건록', '제왕', '쇠', '병', '사', '묘', '절', '태', '양'];
    
    /**
     * 생성자
     * @param SajuEngine $engine
     */
    public function __construct(SajuEngine $engine) {
        $this->engine = $engine;
        $this->ohangAnalysis = new OhangAnalysis($engine);
    }
    
    /**
     * 십신 분석
     * @return array
     */
    public function analyzeSipsin() {
        $dayMaster = $this->engine->getDayMaster();
        $dayMasterIndex = array_search($dayMaster, SajuEngine::CHEONGAN);
        $dayMasterYinyang = SajuEngine::CHEONGAN_YINYANG[$dayMasterIndex];
        $dayMasterElement = SajuEngine::CHEONGAN_OHANG[$dayMaster];
        
        $result = $this->engine->getResult();
        $pillars = ['year_pillar', 'month_pillar', 'day_pillar', 'hour_pillar'];
        $pillarNames = ['년주', '월주', '일주', '시주'];
        
        $sipsinResult = [];
        
        foreach ($pillars as $i => $pillarKey) {
            $pillar = $result[$pillarKey];
            
            // 천간의 십신
            $stemSipsin = $this->getSipsin($dayMasterElement, $dayMasterYinyang,
                $pillar['stem_element'], SajuEngine::CHEONGAN_YINYANG[$pillar['stem_index']]);
            
            // 지지의 십신
            $branchSipsin = $this->getSipsin($dayMasterElement, $dayMasterYinyang,
                $pillar['branch_element'], SajuEngine::JIJI_YINYANG[$pillar['branch_index']]);
            
            // 12운성
            $twelveStage = $this->getTwelveStage($dayMasterIndex, $pillar['branch_index']);
            
            $sipsinResult[] = [
                'pillar_name' => $pillarNames[$i],
                'stem' => $pillar['stem'],
                'branch' => $pillar['branch'],
                'stem_sipsin' => $stemSipsin,
                'branch_sipsin' => $branchSipsin,
                'twelve_stage' => $twelveStage,
                'stem_sipsin_info' => self::SIPSIN_INFO[$stemSipsin] ?? [],
                'branch_sipsin_info' => self::SIPSIN_INFO[$branchSipsin] ?? [],
            ];
        }
        
        // 십신 통계
        $sipsinCount = [];
        foreach ($sipsinResult as $item) {
            if ($item['pillar_name'] !== '일주' || true) {
                $sipsinCount[$item['stem_sipsin']] = ($sipsinCount[$item['stem_sipsin']] ?? 0) + 1;
                $sipsinCount[$item['branch_sipsin']] = ($sipsinCount[$item['branch_sipsin']] ?? 0) + 1;
            }
        }
        
        // 주요 십신 (가장 많은 십신)
        arsort($sipsinCount);
        $dominantSipsin = array_key_first($sipsinCount);
        
        return [
            'pillars' => $sipsinResult,
            'sipsin_count' => $sipsinCount,
            'dominant_sipsin' => $dominantSipsin,
            'dominant_sipsin_info' => self::SIPSIN_INFO[$dominantSipsin] ?? [],
            'interpretation' => $this->interpretSipsin($sipsinCount, $dominantSipsin),
        ];
    }
    
    /**
     * 두 오행 사이의 십신 관계 계산
     * @param string $dayElement 일간 오행
     * @param int $dayYinyang 일간 음양 (0=양, 1=음)
     * @param string $targetElement 대상 오행
     * @param int $targetYinyang 대상 음양
     * @return string 십신 이름
     */
    private function getSipsin($dayElement, $dayYinyang, $targetElement, $targetYinyang) {
        $sameYinyang = ($dayYinyang === $targetYinyang);
        
        // 같은 오행
        if ($dayElement === $targetElement) {
            return $sameYinyang ? '비견' : '겁재';
        }
        
        // 내가 생하는 오행
        $generates = self::OHANG_CYCLE[(array_search($dayElement, self::OHANG_CYCLE) + 1) % 5];
        if ($targetElement === $generates) {
            return $sameYinyang ? '식신' : '상관';
        }
        
        // 내가 극하는 오행
        $controls = self::OHANG_CYCLE[(array_search($dayElement, self::OHANG_CYCLE) + 2) % 5];
        if ($targetElement === $controls) {
            return $sameYinyang ? '편재' : '정재';
        }
        
        // 나를 극하는 오행
        $controlledBy = self::OHANG_CYCLE[(array_search($dayElement, self::OHANG_CYCLE) + 3) % 5];
        if ($targetElement === $controlledBy) {
            return $sameYinyang ? '편관' : '정관';
        }
        
        // 나를 생하는 오행
        $generatedBy = self::OHANG_CYCLE[(array_search($dayElement, self::OHANG_CYCLE) + 4) % 5];
        if ($targetElement === $generatedBy) {
            return $sameYinyang ? '편인' : '정인';
        }
        
        return '비견'; // 기본값
    }
    
    /**
     * 12운성 계산
     * @param int $dayStemIndex 일간 천간 인덱스
     * @param int $branchIndex 지지 인덱스
     * @return string
     */
    private function getTwelveStage($dayStemIndex, $branchIndex) {
        // 12운성 시작 지지 (천간별)
        // 갑→해(11), 을→오(6), 병→인(2), 정→유(9), 무→인(2)
        // 기→유(9), 경→사(5), 신→자(0), 임→신(8), 계→묘(3)
        $startBranch = [11, 6, 2, 9, 2, 9, 5, 0, 8, 3];
        
        $start = $startBranch[$dayStemIndex];
        $isYang = SajuEngine::CHEONGAN_YINYANG[$dayStemIndex] === 0;
        
        if ($isYang) {
            $index = ($branchIndex - $start + 12) % 12;
        } else {
            $index = ($start - $branchIndex + 12) % 12;
        }
        
        return self::TWELVE_STAGES[$index];
    }
    
    /**
     * 십신 해석 생성
     * @param array $sipsinCount
     * @param string $dominant
     * @return string
     */
    private function interpretSipsin($sipsinCount, $dominant) {
        $interpretations = [
            '비견' => '독립심이 강하고 자기 주관이 뚜렷합니다. 동료나 형제와의 관계에서 배울 점이 많으며, 경쟁을 통해 성장합니다.',
            '겁재' => '활동적이고 사교적인 성격입니다. 대인관계가 넓지만 재물 관리에 주의가 필요합니다.',
            '식신' => '예술적 감각과 창의력이 뛰어납니다. 식복이 있고 표현력이 좋아 사람들에게 호감을 줍니다.',
            '상관' => '재능이 많고 언변이 좋습니다. 기존 틀에 얽매이지 않는 자유로운 사고를 합니다.',
            '편재' => '사업적 수완이 좋고 재물을 모으는 능력이 있습니다. 투자와 사업에서 기회를 잘 포착합니다.',
            '정재' => '근면하고 성실하여 안정적인 재물을 쌓아갑니다. 저축 습관이 좋고 계획적입니다.',
            '편관' => '추진력과 리더십이 있습니다. 도전적인 삶을 살며 큰 업적을 이룰 수 있는 기질입니다.',
            '정관' => '도덕적이고 질서를 중시합니다. 사회적 명예를 얻을 수 있으며 공직이나 큰 조직에 적합합니다.',
            '편인' => '특수한 재능과 학문적 깊이를 가집니다. 독특한 분야에서 두각을 나타낼 수 있습니다.',
            '정인' => '학문적 자질이 뛰어나고 인자한 성품을 가집니다. 교육이나 학문 분야에서 성공할 수 있습니다.',
        ];
        
        return $interpretations[$dominant] ?? '다양한 기운이 조화를 이루고 있습니다.';
    }
    
    /**
     * 격국 분석
     * @return array
     */
    public function analyzeGyeokguk() {
        $dayMasterElement = $this->engine->getDayMasterElement();
        $ohangData = $this->ohangAnalysis->analyze();
        $ohangCount = $ohangData['ohang_count'];
        
        // 일간과 같은 오행 + 일간을 생하는 오행 = 신강/신약 판단
        $generatedBy = self::OHANG_CYCLE[(array_search($dayMasterElement, self::OHANG_CYCLE) + 4) % 5];
        $selfStrength = ($ohangCount[$dayMasterElement] ?? 0) + ($ohangCount[$generatedBy] ?? 0);
        $totalElements = array_sum($ohangCount);
        $isStrong = $selfStrength >= ($totalElements / 2);
        
        // 격국 유형 결정
        $gyeokgukType = $isStrong ? 'strong_self' : 'weak_self';
        
        // 세부 격국 판단 (월지 기준)
        $result = $this->engine->getResult();
        $monthBranchElement = $result['month_pillar']['branch_element'];
        $monthBranchSipsin = $this->getSipsin(
            $dayMasterElement,
            SajuEngine::CHEONGAN_YINYANG[$result['day_pillar']['stem_index']],
            $monthBranchElement,
            SajuEngine::JIJI_YINYANG[$result['month_pillar']['branch_index']]
        );
        
        // 월지 십신별 세부 격국
        $detailGyeokguk = $this->getDetailGyeokguk($monthBranchSipsin);
        
        // 용신(用神) 결정
        $yongsin = $this->determineYongsin($isStrong, $dayMasterElement);
        
        return [
            'is_strong' => $isStrong,
            'type' => $gyeokgukType,
            'type_name' => self::GYEOKGUK_TYPES[$gyeokgukType],
            'self_strength' => $selfStrength,
            'total_elements' => $totalElements,
            'detail_gyeokguk' => $detailGyeokguk,
            'yongsin' => $yongsin,
            'interpretation' => $this->interpretGyeokguk($isStrong, $dayMasterElement, $detailGyeokguk),
        ];
    }
    
    /**
     * 세부 격국 판단
     * @param string $monthSipsin
     * @return string
     */
    private function getDetailGyeokguk($monthSipsin) {
        $map = [
            '식신' => 'food_god', '상관' => 'food_god',
            '편재' => 'wealth', '정재' => 'wealth',
            '편관' => 'official', '정관' => 'official',
            '편인' => 'seal', '정인' => 'seal',
            '비견' => 'comparison', '겁재' => 'comparison',
        ];
        return $map[$monthSipsin] ?? 'comparison';
    }
    
    /**
     * 용신 결정
     * @param bool $isStrong
     * @param string $dayElement
     * @return array
     */
    private function determineYongsin($isStrong, $dayElement) {
        if ($isStrong) {
            // 신강: 설기하거나 극하는 오행이 용신
            $controls = self::OHANG_CYCLE[(array_search($dayElement, self::OHANG_CYCLE) + 2) % 5]; // 재성
            $generates = self::OHANG_CYCLE[(array_search($dayElement, self::OHANG_CYCLE) + 1) % 5]; // 식상
            return [
                'element' => $controls,
                'description' => sprintf("신강한 사주로 %s(%s)의 기운이 용신입니다. %s의 기운도 도움이 됩니다.",
                    $controls, OhangAnalysis::OHANG_PROPERTIES[$controls]['hanja'],
                    $generates
                )
            ];
        } else {
            // 신약: 일간을 생하거나 돕는 오행이 용신
            $generatedBy = self::OHANG_CYCLE[(array_search($dayElement, self::OHANG_CYCLE) + 4) % 5]; // 인성
            return [
                'element' => $generatedBy,
                'description' => sprintf("신약한 사주로 %s(%s)의 기운이 용신입니다. %s의 기운도 도움이 됩니다.",
                    $generatedBy, OhangAnalysis::OHANG_PROPERTIES[$generatedBy]['hanja'],
                    $dayElement
                )
            ];
        }
    }
    
    /**
     * 격국 해석
     * @param bool $isStrong
     * @param string $dayElement
     * @param string $detailType
     * @return string
     */
    private function interpretGyeokguk($isStrong, $dayElement, $detailType) {
        $typeNames = [
            'food_god' => '식신격',
            'wealth' => '재성격',
            'official' => '관성격',
            'seal' => '인성격',
            'comparison' => '비겁격',
        ];
        
        $typeInterpretations = [
            'food_god' => '창의력과 표현력이 뛰어나며 예술, 요식업, 콘텐츠 분야에서 재능을 발휘할 수 있습니다. 식복이 있어 먹거리에 대한 안목도 갖추고 있습니다.',
            'wealth' => '재물에 대한 감각이 좋고 사업이나 투자에서 성과를 낼 수 있습니다. 근면성실한 노력으로 재산을 모을 수 있는 격국입니다.',
            'official' => '리더십과 책임감이 강하여 조직에서 높은 직위에 오를 수 있습니다. 공직이나 대기업에서 능력을 발휘합니다.',
            'seal' => '학문적 재능이 뛰어나고 깊은 사색을 즐깁니다. 교육, 연구, 전문직 분야에서 두각을 나타냅니다.',
            'comparison' => '독립적이고 자기 주관이 뚜렷합니다. 자영업이나 프리랜서로서 성공할 가능성이 높습니다.',
        ];
        
        $strengthDesc = $isStrong ?
            '신강한 사주로 자신감과 추진력이 강합니다. 에너지가 넘치므로 이를 적절히 발산하는 것이 중요합니다.' :
            '신약한 사주로 섬세하고 신중합니다. 주변의 도움을 잘 활용하면 큰 성과를 이룰 수 있습니다.';
        
        $typeName = $typeNames[$detailType] ?? '혼합격';
        $typeInterp = $typeInterpretations[$detailType] ?? '다양한 기운이 조화를 이루고 있습니다.';
        
        return sprintf("당신의 격국은 %s이며, %s입니다. %s %s",
            $isStrong ? '신강(身強)' : '신약(身弱)',
            $typeName,
            $strengthDesc,
            $typeInterp
        );
    }
    
    /**
     * 대운 분석 (10년 단위 운세 흐름)
     * @return array
     */
    public function analyzeDaeun() {
        $result = $this->engine->getResult();
        $gender = $result['input']['gender'];
        $yearStemYinyang = SajuEngine::CHEONGAN_YINYANG[$result['year_pillar']['stem_index']];
        
        // 대운 순행/역행 결정
        // 남자+양년간 또는 여자+음년간 → 순행
        // 남자+음년간 또는 여자+양년간 → 역행
        $isForward = ($gender === 'male' && $yearStemYinyang === 0) ||
                     ($gender === 'female' && $yearStemYinyang === 1);
        
        // 월주를 기준으로 대운 생성
        $monthStem = $result['month_pillar']['stem_index'];
        $monthBranch = $result['month_pillar']['branch_index'];
        
        $daeunList = [];
        $dayMasterElement = $this->engine->getDayMasterElement();
        $dayMasterIndex = array_search($this->engine->getDayMaster(), SajuEngine::CHEONGAN);
        $dayMasterYinyang = SajuEngine::CHEONGAN_YINYANG[$dayMasterIndex];
        
        // 대운 시작 나이 계산 (간략화)
        $startAge = $this->calculateDaeunStartAge($result['input'], $isForward);
        
        for ($i = 1; $i <= 8; $i++) {
            if ($isForward) {
                $stem = ($monthStem + $i) % 10;
                $branch = ($monthBranch + $i) % 12;
            } else {
                $stem = ($monthStem - $i + 10) % 10;
                $branch = ($monthBranch - $i + 12) % 12;
            }
            
            $stemChar = SajuEngine::CHEONGAN[$stem];
            $branchChar = SajuEngine::JIJI[$branch];
            $stemElement = SajuEngine::CHEONGAN_OHANG[$stemChar];
            $branchElement = SajuEngine::JIJI_OHANG[$branchChar];
            
            $ageStart = $startAge + ($i - 1) * 10;
            $ageEnd = $ageStart + 9;
            
            $sipsin = $this->getSipsin($dayMasterElement, $dayMasterYinyang,
                $stemElement, SajuEngine::CHEONGAN_YINYANG[$stem]);
            
            $daeunList[] = [
                'index' => $i,
                'stem' => $stemChar,
                'branch' => $branchChar,
                'stem_hanja' => SajuEngine::CHEONGAN_HANJA[$stem],
                'branch_hanja' => SajuEngine::JIJI_HANJA[$branch],
                'stem_element' => $stemElement,
                'branch_element' => $branchElement,
                'age_start' => $ageStart,
                'age_end' => $ageEnd,
                'sipsin' => $sipsin,
                'interpretation' => $this->interpretDaeun($sipsin, $stemElement, $branchElement, $ageStart, $ageEnd),
                'score' => $this->calculateDaeunScore($dayMasterElement, $stemElement, $branchElement),
            ];
        }
        
        return [
            'direction' => $isForward ? '순행' : '역행',
            'start_age' => $startAge,
            'daeun_list' => $daeunList,
            'summary' => $this->summarizeDaeun($daeunList),
        ];
    }
    
    /**
     * 대운 시작 나이 계산 (간략화)
     * @param array $input
     * @param bool $isForward
     * @return int
     */
    private function calculateDaeunStartAge($input, $isForward) {
        $month = $input['month'];
        $day = $input['day'];
        
        // 절기까지의 거리를 기반으로 대운 시작 나이 계산
        $sajuMonth = 1;
        foreach (self::JEOLGI_DATES as $sm => $jeolgi) {
            if ($month == $jeolgi[0] && $day >= $jeolgi[1]) {
                $sajuMonth = $sm;
            }
        }
        
        // 간략화: 생일부터 다음/이전 절기까지의 일수 ÷ 3 = 대운 시작 나이
        // 여기서는 평균적으로 3~7세 사이로 근사
        $daysToNextJeolgi = abs(15 - $day); // 대략적 계산
        $startAge = max(1, (int)round($daysToNextJeolgi / 3));
        
        // 범위 제한
        return max(1, min(10, $startAge));
    }
    
    /**
     * 대운 해석
     */
    private function interpretDaeun($sipsin, $stemElement, $branchElement, $ageStart, $ageEnd) {
        $sipsinMeanings = [
            '비견' => '독립적인 활동과 자기 발전에 유리한 시기입니다. 동료와의 경쟁을 통해 성장하며, 자기만의 길을 개척하게 됩니다.',
            '겁재' => '사교 활동이 활발해지고 새로운 인연이 많아지는 시기입니다. 다만 재물 관리에 주의가 필요합니다.',
            '식신' => '창의적 활동과 표현에 유리한 시기입니다. 예술, 문화 활동이 풍성해지고 식복도 따릅니다.',
            '상관' => '변화와 도전의 시기입니다. 기존 틀을 벗어나 새로운 시도를 하게 되며, 자유로운 활동이 많아집니다.',
            '편재' => '재물운이 활발한 시기입니다. 투자나 사업에서 기회가 오며, 적극적인 재테크가 유리합니다.',
            '정재' => '안정적인 수입과 재물 축적의 시기입니다. 근면한 노력의 결실을 맺으며, 경제적 안정을 이룹니다.',
            '편관' => '변화와 도전이 많은 시기입니다. 리더십을 발휘하게 되며, 큰 성취를 위한 시련이 따를 수 있습니다.',
            '정관' => '사회적 명예와 지위가 상승하는 시기입니다. 승진이나 사회적 인정을 받게 되며, 안정적인 성장을 합니다.',
            '편인' => '학문과 자기 개발에 유리한 시기입니다. 새로운 분야를 공부하거나 자격증 취득에 좋습니다.',
            '정인' => '학업과 명예가 상승하는 시기입니다. 지적 성장과 함께 좋은 스승이나 멘토를 만날 수 있습니다.',
        ];
        
        return sprintf("%d세~%d세: %s", $ageStart, $ageEnd,
            $sipsinMeanings[$sipsin] ?? '안정적인 시기입니다.');
    }
    
    /**
     * 대운 점수 계산
     */
    private function calculateDaeunScore($dayMasterElement, $stemElement, $branchElement) {
        $score = 70; // 기본 점수
        
        // 일간을 생하는 오행이면 +
        $generatedBy = self::OHANG_CYCLE[(array_search($dayMasterElement, self::OHANG_CYCLE) + 4) % 5];
        if ($stemElement === $generatedBy || $branchElement === $generatedBy) $score += 10;
        
        // 같은 오행이면 +
        if ($stemElement === $dayMasterElement || $branchElement === $dayMasterElement) $score += 5;
        
        // 극하는 오행이면 -
        $controlledBy = self::OHANG_CYCLE[(array_search($dayMasterElement, self::OHANG_CYCLE) + 3) % 5];
        if ($stemElement === $controlledBy || $branchElement === $controlledBy) $score -= 10;
        
        return max(30, min(100, $score + rand(-5, 10)));
    }
    
    /**
     * 대운 종합 요약
     */
    private function summarizeDaeun($daeunList) {
        $bestPeriod = null;
        $bestScore = 0;
        
        foreach ($daeunList as $daeun) {
            if ($daeun['score'] > $bestScore) {
                $bestScore = $daeun['score'];
                $bestPeriod = $daeun;
            }
        }
        
        if ($bestPeriod) {
            return sprintf("인생에서 가장 좋은 대운은 %d세~%d세(%s%s운)로, 이 시기에 중요한 결정이나 도전을 하면 좋은 결과를 얻을 수 있습니다.",
                $bestPeriod['age_start'], $bestPeriod['age_end'],
                $bestPeriod['stem'], $bestPeriod['branch']
            );
        }
        
        return "전반적으로 안정적인 대운 흐름을 보이고 있습니다.";
    }
    
    /**
     * 세운 분석 (올해의 운세)
     * @param int|null $year 분석할 년도 (기본: 올해)
     * @return array
     */
    public function analyzeSeun($year = null) {
        if ($year === null) $year = (int)date('Y');
        
        $dayMasterElement = $this->engine->getDayMasterElement();
        $dayMasterIndex = array_search($this->engine->getDayMaster(), SajuEngine::CHEONGAN);
        $dayMasterYinyang = SajuEngine::CHEONGAN_YINYANG[$dayMasterIndex];
        
        // 해당 년도의 천간/지지
        $yearStem = ($year - 4) % 10;
        if ($yearStem < 0) $yearStem += 10;
        $yearBranch = ($year - 4) % 12;
        if ($yearBranch < 0) $yearBranch += 12;
        
        $stemChar = SajuEngine::CHEONGAN[$yearStem];
        $branchChar = SajuEngine::JIJI[$yearBranch];
        $stemElement = SajuEngine::CHEONGAN_OHANG[$stemChar];
        $branchElement = SajuEngine::JIJI_OHANG[$branchChar];
        
        $sipsin = $this->getSipsin($dayMasterElement, $dayMasterYinyang,
            $stemElement, SajuEngine::CHEONGAN_YINYANG[$yearStem]);
        
        // 총운 점수
        $totalScore = $this->calculateSeunScore($dayMasterElement, $stemElement, $branchElement);
        
        // 카테고리별 운세 점수
        $categories = $this->calculateCategoryScores($dayMasterElement, $stemElement, $branchElement, $sipsin);
        
        return [
            'year' => $year,
            'stem' => $stemChar,
            'branch' => $branchChar,
            'stem_hanja' => SajuEngine::CHEONGAN_HANJA[$yearStem],
            'branch_hanja' => SajuEngine::JIJI_HANJA[$yearBranch],
            'stem_element' => $stemElement,
            'branch_element' => $branchElement,
            'zodiac' => SajuEngine::ZODIAC_ANIMALS[$branchChar],
            'sipsin' => $sipsin,
            'total_score' => $totalScore,
            'categories' => $categories,
            'monthly' => $this->analyzeMonthlySeun($year, $dayMasterElement, $dayMasterYinyang),
            'interpretation' => $this->interpretSeun($sipsin, $totalScore, $year),
        ];
    }
    
    /**
     * 세운 점수 계산
     */
    private function calculateSeunScore($dayMasterElement, $stemElement, $branchElement) {
        $score = 65;
        
        $generatedBy = self::OHANG_CYCLE[(array_search($dayMasterElement, self::OHANG_CYCLE) + 4) % 5];
        if ($stemElement === $generatedBy) $score += 15;
        if ($branchElement === $generatedBy) $score += 10;
        
        if ($stemElement === $dayMasterElement) $score += 5;
        if ($branchElement === $dayMasterElement) $score += 5;
        
        $controlledBy = self::OHANG_CYCLE[(array_search($dayMasterElement, self::OHANG_CYCLE) + 3) % 5];
        if ($stemElement === $controlledBy) $score -= 10;
        if ($branchElement === $controlledBy) $score -= 5;
        
        return max(30, min(100, $score + rand(-5, 10)));
    }
    
    /**
     * 카테고리별 운세 점수
     */
    private function calculateCategoryScores($dayMasterElement, $stemElement, $branchElement, $sipsin) {
        $baseScore = $this->calculateSeunScore($dayMasterElement, $stemElement, $branchElement);
        
        $categories = [
            'total'    => ['name' => '총운', 'score' => $baseScore],
            'study'    => ['name' => '학업운', 'score' => max(30, min(100, $baseScore + rand(-15, 15)))],
            'wealth'   => ['name' => '재물운', 'score' => max(30, min(100, $baseScore + rand(-15, 15)))],
            'health'   => ['name' => '건강운', 'score' => max(30, min(100, $baseScore + rand(-15, 15)))],
            'love'     => ['name' => '연애운', 'score' => max(30, min(100, $baseScore + rand(-15, 15)))],
            'career'   => ['name' => '사업운', 'score' => max(30, min(100, $baseScore + rand(-15, 15)))],
        ];
        
        // 십신별 보정
        if (in_array($sipsin, ['정재', '편재'])) $categories['wealth']['score'] = min(100, $categories['wealth']['score'] + 10);
        if (in_array($sipsin, ['정관', '편관'])) $categories['career']['score'] = min(100, $categories['career']['score'] + 10);
        if (in_array($sipsin, ['정인', '편인'])) $categories['study']['score'] = min(100, $categories['study']['score'] + 10);
        if (in_array($sipsin, ['식신'])) $categories['health']['score'] = min(100, $categories['health']['score'] + 10);
        
        return $categories;
    }
    
    /**
     * 월별 세운 분석
     */
    private function analyzeMonthlySeun($year, $dayMasterElement, $dayMasterYinyang) {
        $monthly = [];
        
        for ($m = 1; $m <= 12; $m++) {
            $yearStem = ($year - 4) % 10;
            if ($yearStem < 0) $yearStem += 10;
            
            $monthStemStart = ($yearStem % 5) * 2 + 2;
            $monthStem = ($monthStemStart + $m - 1) % 10;
            $monthBranch = ($m + 1) % 12;
            
            $stemChar = SajuEngine::CHEONGAN[$monthStem];
            $stemElement = SajuEngine::CHEONGAN_OHANG[$stemChar];
            $branchChar = SajuEngine::JIJI[$monthBranch];
            $branchElement = SajuEngine::JIJI_OHANG[$branchChar];
            
            $score = $this->calculateSeunScore($dayMasterElement, $stemElement, $branchElement);
            
            $monthly[] = [
                'month' => $m,
                'stem' => $stemChar,
                'branch' => $branchChar,
                'score' => $score,
                'brief' => $this->getMonthlyBrief($score),
            ];
        }
        
        return $monthly;
    }
    
    /**
     * 월별 간략 해석
     */
    private function getMonthlyBrief($score) {
        if ($score >= 85) return '매우 좋은 달';
        if ($score >= 70) return '좋은 달';
        if ($score >= 55) return '보통의 달';
        if ($score >= 40) return '주의가 필요한 달';
        return '조심해야 할 달';
    }
    
    /**
     * 세운 해석
     */
    private function interpretSeun($sipsin, $score, $year) {
        $scoreDesc = '';
        if ($score >= 85) $scoreDesc = '매우 좋은 한 해가 될 것입니다.';
        elseif ($score >= 70) $scoreDesc = '전반적으로 좋은 운세를 보이는 한 해입니다.';
        elseif ($score >= 55) $scoreDesc = '보통의 운세로, 차분하게 준비하는 것이 좋습니다.';
        elseif ($score >= 40) $scoreDesc = '주의가 필요한 한 해로, 신중한 결정이 중요합니다.';
        else $scoreDesc = '도전과 시련의 한 해로, 인내와 지혜가 필요합니다.';
        
        $sipsinAdvice = [
            '비견' => '동료나 형제와의 협력이 중요한 해입니다. 경쟁보다 화합을 통해 더 큰 성과를 이룰 수 있습니다.',
            '겁재' => '재물 관리에 특히 주의하고, 새로운 인연을 소중히 여기세요.',
            '식신' => '창의적 활동과 표현에 집중하면 좋은 결과가 있을 것입니다.',
            '상관' => '변화를 두려워하지 말고 새로운 도전을 시도해 보세요.',
            '편재' => '투자와 사업에서 좋은 기회가 올 수 있습니다. 다만 과욕은 금물입니다.',
            '정재' => '꾸준한 노력이 결실을 맺는 해입니다. 저축과 안정적인 관리가 유리합니다.',
            '편관' => '큰 변화나 승진의 기회가 있을 수 있습니다. 도전적으로 임하세요.',
            '정관' => '사회적 인정과 명예가 따르는 해입니다. 책임감을 가지고 임하세요.',
            '편인' => '공부나 자기 개발에 투자하면 좋은 해입니다.',
            '정인' => '학업이나 시험에서 좋은 결과를 기대할 수 있습니다.',
        ];
        
        return sprintf("%d년: %s %s", $year, $scoreDesc, $sipsinAdvice[$sipsin] ?? '');
    }
    
    /**
     * 종합 운세 해석 (성격, 연애, 직업, 재물, 학문, 인생)
     * @return array
     */
    public function getComprehensiveFortune() {
        $result = $this->engine->getResult();
        $dayMaster = $result['day_master'];
        $dayMasterElement = $result['day_master_element'];
        $gender = $result['input']['gender'];
        $ohang = $this->ohangAnalysis->analyze();
        
        return [
            'personality' => $this->interpretPersonality($dayMaster, $dayMasterElement, $gender),
            'love' => $this->interpretLove($dayMaster, $dayMasterElement, $gender),
            'career' => $this->interpretCareer($dayMaster, $dayMasterElement),
            'wealth' => $this->interpretWealth($dayMaster, $dayMasterElement),
            'study' => $this->interpretStudy($dayMaster, $dayMasterElement),
            'life_flow' => $this->interpretLifeFlow($dayMaster, $dayMasterElement, $gender),
        ];
    }
    
