    /**
     * 인생 전반 흐름
     */
    private function interpretLifeFlow($dayMaster, $element, $gender) {
        $flows = [
            '갑' => [
                'early' => '어린 시절 활발하고 에너지가 넘치며, 학교에서 리더 역할을 자연스럽게 맡게 됩니다.',
                'youth' => '청년기에 큰 포부를 품고 도전하며, 혼자서도 잘 해나가는 독립적인 모습을 보입니다.',
                'middle' => '중년기에 자신만의 분야에서 확고한 위치를 잡으며, 리더십을 발휘하여 많은 사람을 이끕니다.',
                'later' => '후반기에는 쌓아온 경험과 지혜로 후배들에게 존경받으며, 안정적인 노후를 보냅니다.',
            ],
            '을' => [
                'early' => '어린 시절 사교적이고 예술적 감각이 뛰어나며, 다양한 친구들과 잘 어울립니다.',
                'youth' => '청년기에 여러 경험을 통해 자신만의 방향을 찾아가며, 유연하게 환경에 적응합니다.',
                'middle' => '중년기에 꾸준히 쌓아온 실력이 인정받으며, 한 분야에서 전문가로 자리잡습니다.',
                'later' => '후반기에는 풍요로운 인간관계 속에서 행복한 시간을 보냅니다.',
            ],
        ];
        
        // 기본값 설정 (개별 일간별 데이터가 없는 경우)
        $defaultFlow = [
            'early' => '어린 시절 다양한 경험을 통해 기본기를 다지며, 자신만의 특성을 발견하게 됩니다.',
            'youth' => '청년기에 적극적으로 세상에 도전하며, 인생의 방향을 설정하는 중요한 시기입니다.',
            'middle' => '중년기에 걸쳐 사회적으로 안정을 이루며, 가정과 직업에서 균형을 찾아갑니다.',
            'later' => '후반기에는 지혜로운 삶을 영위하며, 내면의 평화와 주변의 사랑을 넒게 누립니다.',
        ];
        
        $flow = $flows[$dayMaster] ?? $defaultFlow;
        
        return [
            'title' => '인생 전반 흐름',
            'content' => sprintf(
                "【초년운(0~20세)】\n%s\n\n【청년운(20~40세)】\n%s\n\n【중년운(40~60세)】\n%s\n\n【말년운(60세~)】\n%s",
                $flow['early'], $flow['youth'], $flow['middle'], $flow['later']
            ),
        ];
    }
    
