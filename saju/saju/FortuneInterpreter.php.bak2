    private function interpretCareer($dayMaster, $element) {
        $careers = [
            '갑' => '리더십과 추진력이 강한 당신은 경영, 관리직, 정치, 법률 분야에 적합합니다. 큰 조직을 이끄는 CEO나 임원, 또는 독립적인 사업도 잘 어울립니다. 교육자나 상담사로서도 재능을 발휘할 수 있습니다. 건설, 목재, 가구 관련 업종도 좋습니다.',
            '을' => '유연한 적응력을 바탕으로 서비스업, 예술, 디자인, 패션 분야에서 두각을 나타낼 수 있습니다. 화초, 꽃 관련 사업이나 인테리어 분야도 적합합니다. 중개/협상 업무에서 뛰어난 능력을 보입니다.',
            '병' => '밝고 적극적인 성격으로 미디어, 엔터테인먼트, 교육, 홍보 분야에 적합합니다. 사람들 앞에 서는 직업이 잘 맞으며 방송인, 강사, 마케터로 성공할 수 있습니다.',
            '정' => '섬세한 감각을 살려 예술, 문학, 음악, 공예 분야에서 재능을 발휘할 수 있습니다. IT, 기술 분야에서의 전문직도 적합합니다. 연구직이나 분석 업무에서도 뛰어납니다.',
            '무' => '안정적이고 듬직한 성격으로 부동산, 건설, 농업, 공무원 분야에 적합합니다. 대기업 관리직이나 금융 분야에서도 능력을 발휘합니다. 신뢰를 바탕으로 한 사업이 유리합니다.',
            '기' => '꼼꼼하고 배려심있는 성격으로 의료, 교육, 복지, 요식업 분야에 적합합니다. 농업이나 식품 관련 사업도 좋습니다. 서비스직에서 고객 만족도를 높이는 능력이 있습니다.',
            '경' => '결단력과 추진력으로 군인, 경찰, 법률, 금융 분야에 적합합니다. 기계, 금속, IT 하드웨어 관련 업종도 좋습니다. 스포츠나 체력을 활용하는 분야에서도 성공할 수 있습니다.',
            '신' => '세련된 감각과 완벽주의로 주얼리, 패션, 미용, 금융 분야에 적합합니다. 회계, 감사 등 정밀한 업무에서 능력을 발휘합니다. 의료 분야(치과, 성형 등)도 잘 맞습니다.',
            '임' => '넓은 시야와 창의성으로 무역, 물류, 해운, 관광 분야에 적합합니다. IT, 소프트웨어 개발에서도 뛰어난 능력을 보입니다. 국제 비즈니스에서 역량을 발휘할 수 있습니다.',
            '계' => '깊은 분석력과 지적 능력으로 연구, 학문, 컨설팅, 데이터 분석 분야에 적합합니다. 의학, 약학, 화학 관련 분야도 좋습니다. 작가, 기자 등 글쓰기 관련 직종에서도 재능을 발휘합니다.',
        ];
        
        return [
            'title' => '직업운 · 직장운',
            'content' => $careers[$dayMaster] ?? '다양한 분야에서 능력을 발휘할 수 있습니다.',
        ];
    }
    
    /**
     * 재물운
     */
    private function interpretWealth($dayMaster, $element) {
        $wealth = [
            '갑' => '큰 꿈을 가지고 사업을 통해 큰 재물을 모을 수 있는 사주입니다. 초반에는 투자가 필요하지만 중장기적으로 안정적인 수입을 기대할 수 있습니다. 부동산이나 주식 등 장기 투자에 유리합니다. 자기 사업을 통한 수입이 가장 큰 재물의 원천이 됩니다.',
            '을' => '다양한 루트를 통해 재물이 들어오는 타입입니다. 한 가지 큰 수입보다 여러 작은 수입이 모여 재산을 이룹니다. 저축과 재테크에 관심을 가지면 안정적인 재물을 쌓을 수 있습니다.',
            '병' => '번 만큼 쓰는 타입이지만 전체적으로 재물운이 좋습니다. 사람을 통해 재물이 들어오며, 사교 활동이 재물과 연결됩니다. 투자보다 실업 수입이 유리하며, 낙관적 성격이 재물을 끌어당깁니다.',
            '정' => '꾸준히 모아가는 타입으로 갑자기 큰 돈보다 차곡차곡 쌓아가는 재물이 많습니다. 기술이나 재능을 활용한 수입이 유리합니다. 전문 분야에서의 성공이 재물로 이어집니다.',
            '무' => '안정적이고 든든한 재물운을 가졌습니다. 부동산이나 토지를 통한 수입이 유리합니다. 급격한 변화보다 꾸준한 축적을 통해 재물을 모읍니다. 중년 이후 재물운이 더욱 좋아집니다.',
            '기' => '실속 있는 재물운입니다. 외형적 화려함보다 실질적 수입에 능합니다. 식품이나 서비스업을 통한 수입이 유리합니다. 꾸준한 노력이 안정적인 재물로 이어집니다.',
            '경' => '강한 추진력으로 사업에서 큰 수입을 올릴 수 있습니다. 금융이나 금속 관련 투자에 유리합니다. 결단력 있는 투자가 성공으로 이어지며, 중년 이후 재물이 안정됩니다.',
            '신' => '세련된 감각을 활용한 사업이나 투자에서 수입을 올립니다. 귀금속이나 금융 관련 분야에서 재물이 들어옵니다. 안목과 심미안을 살린 사업이 성공으로 이어집니다.',
            '임' => '큰 흐름을 읽는 능력으로 무역이나 유통에서 큰 재물을 모을 수 있습니다. 해외 관련 사업이나 투자에서 기회가 옵니다. 변동성이 있지만 전체적으로 풍요로운 재물운입니다.',
            '계' => '지적 능력을 활용한 수입이 유리합니다. 전문직이나 연구 분야에서 안정적인 수입을 올립니다. 과하지 않게 알뜰하게 관리하는 능력이 있어 재물을 잘 지킵니다.',
        ];
        
        return [
            'title' => '재물운',
            'content' => $wealth[$dayMaster] ?? '꾸준한 노력으로 안정적인 재물을 모을 수 있습니다.',
        ];
    }
    
